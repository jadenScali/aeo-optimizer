{% comment %}
  Pings the app proxy path configured in shopify.app.toml (default /apps/aeo-ai-ref).
  Merchants must enable this app embed under Theme settings > App embeds.
{% endcomment %}
<script>
  (function () {
    var proxyPath = "/apps/aeo-ai-ref";
    try {
      var params = new URLSearchParams(window.location.search);
      var ref = document.referrer;
      if (ref) {
        try {
          params.set("ref_host", new URL(ref).hostname);
        } catch (e) {}
      }
      var day = new Date().toISOString().slice(0, 10);
      var dedupeKey = "aeoAiRef:" + day + ":" + window.location.pathname;
      if (sessionStorage.getItem(dedupeKey)) return;
      sessionStorage.setItem(dedupeKey, "1");
      var url = proxyPath + "?" + params.toString();
      if (typeof fetch === "function") {
        fetch(url, {
          method: "GET",
          credentials: "same-origin",
          keepalive: true,
        }).catch(function () {});
      } else {
        var img = new Image();
        img.src = url;
      }
    } catch (err) {}
  })();
</script>

{% schema %}
{
  "name": "AEO AI referrer tracking",
  "target": "body",
  "settings": []
}
{% endschema %}
